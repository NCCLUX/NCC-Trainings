<?xml version="1.0" encoding="UTF-8" ?> <?xml-stylesheet type="text/xsl" href="rss.xsl"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:dc="http://purl.org/dc/elements/1.1/"> <channel> <title>SuperComputing Luxembourg - National Competence Center</title><description>Material of events hosted by SuperComputing Luxembourg, the National Competence Centre in High-Performance Computing</description><link>https://ncclux.github.io/NCC-Trainings/</link><atom:link href="https://ncclux.github.io/NCC-Trainings/feed_rss_created.xml" rel="self" type="application/rss+xml" /> <docs>https://github.com/NCCLUX/NCC-Trainings/</docs><language>en</language> <pubDate>Tue, 28 Apr 2026 13:01:36 -0000</pubDate> <lastBuildDate>Tue, 28 Apr 2026 13:01:36 -0000</lastBuildDate> <ttl>1440</ttl> <generator>MkDocs RSS plugin - v1.19.0</generator> <image> <url>figures/Logo_SC_Luxembourg.png</url> <title>SuperComputing Luxembourg - National Competence Center</title> <link>https://ncclux.github.io/NCC-Trainings/</link> </image> <item> <title>Organization</title> <description>&lt;p&gt;This webpage holds the materials of the training events organized by &lt;a href=&#34;https://supercomputing.lu/&#34;&gt;SuperComputing Luxembourg&lt;/a&gt;, the National Competence Centre ...&lt;/p&gt;</description> <link>https://ncclux.github.io/NCC-Trainings/organization/</link> <pubDate>Mon, 27 Apr 2026 18:07:47 +0000</pubDate> <source url="https://ncclux.github.io/NCC-Trainings/feed_rss_created.xml">SuperComputing Luxembourg - National Competence Center</source><guid isPermaLink="true">https://ncclux.github.io/NCC-Trainings/organization/</guid> </item> <item> <title>Instructions for educators</title> <description>&lt;p&gt;If you are an educator and would like to offer a course with us, then &lt;a href=&#34;https://supercomputing.lu/contact-us&#34;&gt;please contact us&lt;/a&gt;.&lt;/p&gt; &lt;p&gt;Please read the following ...&lt;/p&gt;</description> <link>https://ncclux.github.io/NCC-Trainings/orga